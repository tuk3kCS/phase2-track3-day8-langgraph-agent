# LLM API key (required — pick one)
GEMINI_API_KEY=AIza...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: override default model
# LLM_MODEL=gemini-2.5-flash

# Optional: real HITL interrupts (default: mock approval)
# LANGGRAPH_INTERRUPT=true

# Optional: persistence backend
CHECKPOINTER=memory
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/langgraph_lab

LOG_LEVEL=INFO

# LangSmith Tracing & Dashboard configuration
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_api_key
# LANGCHAIN_PROJECT=day08-langgraph-agent-lab
# LANGGRAPH_API_KEY=your_langgraph_api_key

